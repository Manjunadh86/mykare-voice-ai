# ---- OpenAI (required) ----
# Used for the Realtime API (voice agent) and summary generation
OPENAI_API_KEY=

# Realtime model. gpt-4o-realtime-preview is the recommended option.
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17
OPENAI_SUMMARY_MODEL=gpt-4o-mini

# Voice for TTS (alloy, ash, ballad, coral, echo, sage, shimmer, verse)
OPENAI_REALTIME_VOICE=sage

# ---- Server ----
HOST=0.0.0.0
PORT=8000
ENV=development

# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Database ----
DATABASE_URL=sqlite+aiosqlite:///./mykare.db

# ---- Clinic config ----
CLINIC_NAME=Mykare Health
CLINIC_TIMEZONE=Asia/Kolkata
# Comma-separated list of doctors / providers
CLINIC_PROVIDERS=Dr. Aisha Khan,Dr. Rohan Mehta,Dr. Priya Sharma

# ---- Cost tracking (USD per unit, latest published OpenAI Realtime pricing) ----
COST_AUDIO_INPUT_PER_MIN=0.06
COST_AUDIO_OUTPUT_PER_MIN=0.24
COST_TEXT_INPUT_PER_1K=0.005
COST_TEXT_OUTPUT_PER_1K=0.020
